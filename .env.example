OPENAI_API_KEY=your_openai_api_key_here

# Supabase Configuration (for appointment workflow)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Business Configuration
BUSINESS_ID=your_business_uuid_here

# Twilio SMS — required for sending the profile setup link after new patient registration
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890

# Profile setup link sent via SMS to new patients
PROFILE_SETUP_URL=https://your-app.com/complete-profile

# Optional
PORT=5050
